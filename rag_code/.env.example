# code_rag — 코딩 전문 RAG 에이전트 설정
# 실제 사용 시 이 파일을 .env 로 복사해 값을 채운다.

# NAS pgvector (ontology-mcp 와 동일 DB)
DB_DSN=postgresql://eungsang:eung@192.168.0.72:5433/eungsang_DB

# Windows GPU 임베딩 서버 (KURE-v1), ontology-mcp 와 동일 스펙: {"texts":[...],"model":"kure"} -> {"embeddings":[[...]]}
EMBED_URL=http://100.102.174.81:8420/embed
EMBED_MODEL=kure

# Windows Ollama — 코딩 LLM
OLLAMA_HOST=http://100.102.174.81:11434
CODE_MODEL=qwen2.5-coder:14b

# 검색 파라미터
TOP_K=5
