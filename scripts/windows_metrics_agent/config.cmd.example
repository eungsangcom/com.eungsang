@echo off
REM config.cmd.example -> config.cmd 로 복사
REM 임베딩·메트릭 에이전트 공통 Python (Microsoft Store python 3.14 사용 금지)

REM GPU conda 환경 (base 또는 artimuse). Microsoft Store python 3.14 금지
set "PY=C:\ProgramData\anaconda3\python.exe"
REM set "PY=C:\ProgramData\anaconda3\envs\artimuse\python.exe"

set "METRICS_AGENT_PORT=8425"
set "METRICS_OLLAMA_PORT=11434"
set "METRICS_EMBED_PORT=8420"

REM 맥미니와 동일 값 (원격 기동 인증)
REM set "WINDOWS_CONTROL_TOKEN=your-shared-secret"
