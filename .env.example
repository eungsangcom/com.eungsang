# docker compose (맥미니) — cp .env.example .env 후 값 입력
#
# pgvector 컨테이너 (호스트 5433 → 컨테이너 5432)
POSTGRES_USER=eungsang
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=eungsang

# Neo4j (컨테이너 NEO4J_AUTH)
NEO4J_PASSWORD=CHANGE_ME

# Cloudflare Zero Trust → Tunnel → Public Hostname
# 예: api.eungsang.com → http://backend:8000
CLOUDFLARE_TUNNEL_TOKEN=

# 맥미니 — 유저 업로드 NAS 마운트 rw (미설정 시 ./eungsang/apps/uploads)
# UPLOADS_HOST_PATH=/Volumes/project/eungsang.com/upload

# 맥미니 — NAS 루트 rw (bgm·intro·crawscrape 등)
# BGM_HOST_PATH=/Volumes/project/eungsang.com

# 맥미니 — 갤러리 사진 NAS rw
# NAS_PHOTO_HOST_PATH=/Volumes/photo

# 맥미니 — .env 백업 NAS 경로 (scripts/nas/backup-env-to-nas.sh)
# NAS_ENV_DIR=/Volumes/project/eungsang.com/env
