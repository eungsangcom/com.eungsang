# docker compose (맥미니) — cp .env.example .env 후 값 입력
#
# pgvector 컨테이너 (호스트 5433 → 컨테이너 5432)
POSTGRES_USER=eungsang
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=eungsang

# Neo4j (컨테이너 NEO4J_AUTH)
NEO4J_PASSWORD=CHANGE_ME

# Cloudflare Zero Trust → Tunnel → Public Hostname
# 예: api.eungsang.com → http://backend:8000
CLOUDFLARE_TUNNEL_TOKEN=
